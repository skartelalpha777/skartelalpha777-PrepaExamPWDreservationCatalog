{% extends 'base.html.twig' %}

{% block title %}Catalog
{% endblock %}

{% block body %}
	<h1>Catalog</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ catalog.id }}</td>
			</tr>
			<tr>
				<th>Title</th>
				<td>{{ catalog.title }}</td>
			</tr>
			<tr>
				<th>Year</th>
				<td>{{ catalog.year }}</td>
			</tr>
			<tr>
				<th>ValidityDate</th>
				<td>{{ catalog.validityDate ? catalog.validityDate|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>Spectacles de ce catalogue</th>
				<td>
					{% if catalog.shows is not empty %}
						<ol>
							{% for show in catalog.shows %}
								<li>
									{{show.title}}
								</li>

							{% endfor %}
						</ol>
					</td>

				{% else %}
					<p>Aucun Spectacle pour ce catalogue</p>
				{% endif %}
			</tr>
		</tbody>
	</table>
	{% if app.user.role.value == 'ROLE_ADMIN'%}
		<a href="{{path('app_catalog_new_show',{'id':catalog.id})}}">
			Ajouter des Spectacle</a>

	{% endif %}
	{% for message in app.flashes('success') %}
		<div class="flash-notice text-success">
			{{ message }}
		</div>
	{% endfor %}
	<br>

	<a href="{{ path('app_catalog_index') }}">back to list</a>

	<a href="{{ path('app_catalog_edit', {'id': catalog.id}) }}">edit</a>

	{{ include('catalog/_delete_form.html.twig') }}
{% endblock %}
